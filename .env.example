# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YourStrongPassword123!
POSTGRES_DB=LoyaltyApiDb

# ──────────────────────────────────────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────────────────────────────────────
JWT_ISSUER=LoyaltyApi
JWT_AUDIENCE=LoyaltyApiClients
JWT_SECRET_KEY=CHANGE_ME_USE_A_SECURE_256_BIT_KEY_IN_PRODUCTION_1234567890
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# ──────────────────────────────────────────────────────────────────────────────
# Encryption (AES-256 base64-encoded 32-byte key)
# ──────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_BASE64_ENCODED_32_BYTE_KEY_FOR_AES256==

# ──────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_PERMIT_LIMIT=10
RATE_LIMIT_API_WINDOW_SECONDS=60
RATE_LIMIT_API_PERMIT_LIMIT=60

# ──────────────────────────────────────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGIN=http://localhost:3000
