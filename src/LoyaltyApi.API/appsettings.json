{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=LoyaltyApiDb;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "LoyaltyApi",
    "Audience": "LoyaltyApiClients",
    "SecretKey": "CHANGE_ME_USE_A_SECURE_256_BIT_KEY_IN_PRODUCTION_1234567890",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Encryption": {
    "Key": "CHANGE_ME_BASE64_ENCODED_32_BYTE_KEY_FOR_AES256=="
  },
  "RateLimit": {
    "AuthWindowSeconds": 60,
    "AuthPermitLimit": 10,
    "ApiWindowSeconds": 60,
    "ApiPermitLimit": 60
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://localhost:3000" ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/loyalty-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
